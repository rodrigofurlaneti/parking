# ==========================================================================
# Variaveis de ambiente da Parking.API em producao.
#
# Na VM, copie este arquivo para /opt/parkingservice/.env e preencha os
# valores reais. O deploy.yml sobe o container com --env-file apontando
# para esse caminho. NUNCA versione o .env real (apenas este .example).
#
#   sudo mkdir -p /opt/parkingservice
#   sudo cp .env.example /opt/parkingservice/.env
#   sudo nano /opt/parkingservice/.env
# ==========================================================================

ASPNETCORE_ENVIRONMENT=Production

# Aplica as migrations do EF Core automaticamente no startup do container.
APPLY_MIGRATIONS_ON_STARTUP=true

# String de conexao com o SQL Server (ajuste host/porta/senha do seu servidor).
# Use o host real do banco na VM (ex.: 127.0.0.1,1433 se o SQL roda na propria VM).
ConnectionStrings__DefaultConnection=Server=127.0.0.1,1433;Database=ParkingDb;User Id=sa;Password=TROQUE_ESTA_SENHA;TrustServerCertificate=True;

# Configuracao do JWT (mesmas chaves lidas do appsettings.json).
Jwt__Secret=TROQUE_POR_UM_SEGREDO_LONGO_E_ALEATORIO
Jwt__Issuer=Parking
Jwt__Audience=Parking.Client
Jwt__ExpiresInMinutes=60
